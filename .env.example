# ──────────────────────────────────────────────────────────────────────────────
# ManusClaw v4.0 — Environment Configuration Example
# Copy this file to .env and fill in your values.
# Priority: env vars > ~/.manusclaw/.env > ~/.manusclaw/config.yaml > config.toml
# ──────────────────────────────────────────────────────────────────────────────

# ── LLM Provider (pick ONE block below) ──────────────────────────────────────

# OpenAI (default)
OPENAI_API_KEY=sk-...

# Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini
# GOOGLE_API_KEY=AIza...

# Mistral AI
# MISTRAL_API_KEY=...

# AWS Bedrock (no API key needed — uses IAM credentials below)
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_DEFAULT_REGION=us-east-1

# Generic OpenAI-compatible endpoint (Groq, OpenRouter, LM Studio, etc.)
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_...

# Override any model at runtime
# LLM_MODEL_OVERRIDE=gpt-4o-mini

# ── Server ────────────────────────────────────────────────────────────────────

# Protect all API endpoints with a bearer token
# MANUSCLAW_API_KEY=your-secret-server-key

# Restrict CORS to specific origins (comma-separated)
# MANUSCLAW_ALLOWED_ORIGINS=https://your-frontend.com,https://another.com

# ── Cron Scheduler ───────────────────────────────────────────────────────────

# Path to the persisted cron jobs YAML file
# MANUSCLAW_CRON_FILE=/home/user/.manusclaw/cron_jobs.yaml

# ── Messaging Platforms ───────────────────────────────────────────────────────

# Telegram
# TELEGRAM_BOT_TOKEN=...

# Discord
# DISCORD_BOT_TOKEN=...

# Slack
# SLACK_BOT_TOKEN=xoxb-...

# ── Misc ──────────────────────────────────────────────────────────────────────

# Profile name — loads ~/.manusclaw/profiles/<name>/config.yaml + .env
# MANUSCLAW_PROFILE=work

# Redact API keys from all log output (recommended for production)
# MANUSCLAW_REDACT=true

# App environment: dev | prod | test
# APP_ENV=dev

# FAL.ai key for image generation tool
# FAL_KEY=...
