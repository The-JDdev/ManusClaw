# ─────────────────────────────────────────────────────────────────────────────
# ManusClaw Environment Configuration
# Copy this file to `.env` and fill in the values you need.
# .env is NEVER committed to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Environment ──────────────────────────────────────────────────────────────
# Options: dev | prod | test
APP_ENV=dev

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Leave blank to use MockLLM (no real API calls — good for testing).

# OpenAI / Azure OpenAI
OPENAI_API_KEY=

# Anthropic Claude
ANTHROPIC_API_KEY=

# Generic (Ollama, LM Studio, or any OpenAI-compatible endpoint)
LLM_API_KEY=
LLM_BASE_URL=

# ── Server ───────────────────────────────────────────────────────────────────
# Protect the REST API with a key. Leave blank to run unauthenticated.
MANUSCLAW_API_KEY=

# Comma-separated list of allowed CORS origins.
# Leave blank to allow all origins (development only).
MANUSCLAW_ALLOWED_ORIGINS=

# ── Database ─────────────────────────────────────────────────────────────────
# Leave blank to use the default local SQLite database.
MANUSCLAW_DB_PATH=

# ── Logging ──────────────────────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=DEBUG
