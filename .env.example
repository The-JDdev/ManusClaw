# ──────────────────────────────────────────────────────────────────────────────
# ManusClaw v5.0 — Environment Configuration Example
# Copy this file to .env and fill in your values.
# Priority: env vars > ~/.manusclaw/.env > ~/.manusclaw/config.yaml > config.toml
# ──────────────────────────────────────────────────────────────────────────────

# ── LLM Provider (pick ONE block below) ──────────────────────────────────────

# OpenAI (default)
OPENAI_API_KEY=sk-...

# Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini
# GOOGLE_API_KEY=AIza...

# Mistral AI
# MISTRAL_API_KEY=...

# AWS Bedrock (no API key needed — uses IAM credentials below)
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_DEFAULT_REGION=us-east-1

# Generic OpenAI-compatible endpoint (Groq, OpenRouter, LM Studio, etc.)
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_...

# Override any model at runtime
# LLM_MODEL_OVERRIDE=gpt-4o-mini

# ── Server ────────────────────────────────────────────────────────────────────

# Protect all API endpoints with a bearer token
# MANUSCLAW_API_KEY=your-secret-server-key

# Restrict CORS to specific origins (comma-separated)
# MANUSCLAW_ALLOWED_ORIGINS=https://your-frontend.com,https://another.com

# ── Cron Scheduler ───────────────────────────────────────────────────────────

# Path to the persisted cron jobs YAML file
# MANUSCLAW_CRON_FILE=/home/user/.manusclaw/cron_jobs.yaml

# ── Messaging Platforms ───────────────────────────────────────────────────────

# Telegram
# TELEGRAM_BOT_TOKEN=...

# Discord
# DISCORD_BOT_TOKEN=...

# Slack
# SLACK_BOT_TOKEN=xoxb-...

# Signal
# SIGNAL_PHONE_NUMBER=...

# Microsoft Teams
# TEAMS_APP_ID=...
# TEAMS_APP_PASSWORD=...

# Google Chat
# GOOGLE_CHAT_SERVICE_ACCOUNT_JSON=/path/to/service-account.json

# Twitch
# TWITCH_BOT_OAUTH_TOKEN=...
# TWITCH_BOT_USERNAME=...
# TWITCH_CHANNEL=...

# Email (SMTP)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=...
# SMTP_PASSWORD=...

# ── WhatsApp Business Cloud (v5.0) ─────────────────────────────────────────────

# WhatsApp Business Cloud API bearer token
# WHATSAPP_ACCESS_TOKEN=...

# WhatsApp Business phone number ID
# WHATSAPP_BUSINESS_PHONE_ID=...

# Webhook verification token
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=manusclaw_verify

# ── IRC Adapter (v5.0) ────────────────────────────────────────────────────────

# IRC server hostname (e.g., irc.libera.chat)
# IRC_SERVER=irc.libera.chat

# IRC server port (default: 6667, use 6697 for TLS)
# IRC_PORT=6667

# Bot nickname
# IRC_NICK=manusclaw

# Comma-separated channels to join
# IRC_CHANNELS=#general,#dev

# Optional NickServ / server password
# IRC_PASS=...

# ── Matrix Protocol (v5.0) ─────────────────────────────────────────────────────

# Matrix homeserver URL
# MATRIX_HOMESERVER=https://matrix.org

# Matrix access token
# MATRIX_ACCESS_TOKEN=...

# Full Matrix user ID (MXID)
# MATRIX_USER_ID=@bot:matrix.org

# ── Voice System (v5.0) ─────────────────────────────────────────────────────────

# Picovoice wake-word API key (for hardware-accelerated wake detection)
# PICOVOICE_API_KEY=...

# ElevenLabs TTS API key (for high-quality text-to-speech)
# ELEVENLABS_API_KEY=...

# OpenAI API key is reused for OpenAI TTS if set

# ── SSH Server (v5.0) ──────────────────────────────────────────────────────────

# Enable SSH server (default: false)
# MANUSCLAW_SSH_ENABLED=true

# SSH port (default: 2222)
# MANUSCLAW_SSH_PORT=2222

# SSH bind address (default: 0.0.0.0)
# MANUSCLAW_SSH_HOST=0.0.0.0

# Path to SSH host key
# MANUSCLAW_SSH_HOST_KEY=~/.manusclaw/ssh/host_key

# Path to authorized_keys file
# MANUSCLAW_SSH_AUTH_KEYS=~/.manusclaw/ssh/authorized_keys

# ── Gmail Integration (v5.0) ─────────────────────────────────────────────────────

# Google OAuth client ID
# GOOGLE_CLIENT_ID=...

# Google OAuth client secret
# GOOGLE_CLIENT_SECRET=...

# Path to stored Gmail credentials JSON
# GOOGLE_GMAIL_TOKEN_PATH=~/.manusclaw/gmail_token.json

# ── Sandbox Backends (v5.0) ───────────────────────────────────────────────────

# Sandbox backend selection: docker | ssh | openshell (default: docker)
# SANDBOX_BACKEND=docker

# SSH sandbox configuration
# SSH_SANDBOX_HOST=192.168.1.100
# SSH_SANDBOX_USER=manusclaw
# SSH_SANDBOX_KEY_PATH=~/.ssh/id_rsa
# SSH_SANDBOX_PORT=22

# ── Misc ──────────────────────────────────────────────────────────────────────

# Profile name — loads ~/.manusclaw/profiles/<name>/config.yaml + .env
# MANUSCLAW_PROFILE=work

# Redact API keys from all log output (recommended for production)
# MANUSCLAW_REDACT=true

# App environment: dev | prod | test
# APP_ENV=dev

# FAL.ai key for image generation tool
# FAL_KEY=...
